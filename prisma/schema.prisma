// ============================================
// OSS BOOKING SYSTEM — PRISMA SCHEMA
// Industry-standard PostgreSQL schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum BookingType {
  CLASS
  EVENT
  SPACE
}

enum BookingStatus {
  REQUESTED
  PENDING_PAYMENT
  CONFIRMED
  PAYMENT_FAILED
  CANCELLED
  EXPIRED
  DECLINED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum SpaceRequestStatus {
  REQUESTED
  APPROVED_CALL_SCHEDULED
  RESCHEDULE_REQUESTED
  DECLINED
  CONFIRMED
  NOT_PROCEEDING
  FOLLOW_UP_REQUIRED
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  SENT
  FAILED
  PENDING
}

enum PricingType {
  PER_SESSION
  PER_MONTH
}

// ============ TABLES ============

model Booking {
  id              String        @id @default(cuid())
  type            BookingType
  status          BookingStatus @default(PENDING_PAYMENT)

  customerName    String        @map("customer_name")
  customerPhone   String        @map("customer_phone")
  customerEmail   String        @map("customer_email")

  amountPaise     Int           @map("amount_paise")
  currency        String        @default("INR")

  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz(3)
  cancelReason    String?       @map("cancel_reason")

  version         Int           @default(1)
  metadata        Json?

  classSessionId  String?       @map("class_session_id")
  classSession    ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: Restrict)

  eventId         String?       @map("event_id")
  event           Event?        @relation(fields: [eventId], references: [id], onDelete: Restrict)

  spaceRequestId  String?       @unique @map("space_request_id")
  spaceRequest    SpaceRequest? @relation(fields: [spaceRequestId], references: [id], onDelete: Restrict)

  payments        Payment[]
  eventPass       EventPass?
  notifications   NotificationLog[]
  statusHistory   StatusHistory[]

  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(3)

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
  @@index([type, status])
  @@index([customerEmail, type])
  @@index([type, createdAt])
  @@index([deletedAt])
  @@index([eventId])
  @@index([classSessionId])
  @@map("bookings")
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @map("booking_id")
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  provider          String        @default("RAZORPAY")
  razorpayOrderId   String        @unique @map("razorpay_order_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")

  status            PaymentStatus @default(CREATED)
  amountPaise       Int           @map("amount_paise")
  currency          String        @default("INR")

  webhookEventId    String?       @unique @map("webhook_event_id")
  rawPayload        Json?         @map("raw_payload")

  refundedAt        DateTime?     @map("refunded_at") @db.Timestamptz(3)
  refundAmountPaise Int?          @map("refund_amount_paise")

  paymentExpiresAt  DateTime?     @map("payment_expires_at") @db.Timestamptz(3)

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([razorpayOrderId])
  @@index([status])
  @@index([bookingId])
  @@map("payments")
}

model ClassSession {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?   @map("image_url")
  instructor  String?
  location    String?

  startsAt    DateTime  @map("starts_at") @db.Timestamptz(3)
  endsAt      DateTime? @map("ends_at") @db.Timestamptz(3)
  duration    Int       @default(60)
  capacity    Int?
  spotsBooked Int       @default(0) @map("spots_booked")
  pricePaise  Int       @map("price_paise")
  active      Boolean   @default(true)

  isRecurring     Boolean     @default(false) @map("is_recurring")
  recurrenceDays  Int[]       @default([]) @map("recurrence_days")
  timeSlots       Json?       @map("time_slots")
  pricingType     PricingType @default(PER_SESSION) @map("pricing_type")

  bookings    Booking[]

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(3)

  @@index([startsAt])
  @@index([active])
  @@index([active, startsAt])
  @@index([deletedAt])
  @@map("class_sessions")
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  imageUrl    String?     @map("image_url")

  startsAt    DateTime    @map("starts_at") @db.Timestamptz(3)
  endsAt      DateTime?   @map("ends_at") @db.Timestamptz(3)
  venue       String
  pricePaise  Int         @map("price_paise")
  capacity    Int?
  active      Boolean     @default(true)

  bookings    Booking[]
  eventPasses EventPass[]

  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(3)

  @@index([startsAt])
  @@index([active])
  @@index([active, startsAt])
  @@index([deletedAt])
  @@map("events")
}

model EventPass {
  id            String        @id @default(cuid())
  bookingId     String        @unique @map("booking_id")
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  eventId       String        @map("event_id")
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  passId        String        @unique @map("pass_id")
  qrImageUrl    String        @map("qr_image_url")

  checkInStatus CheckInStatus @default(NOT_CHECKED_IN) @map("check_in_status")
  checkInTime   DateTime?     @map("check_in_time") @db.Timestamptz(3)
  checkedInBy   String?       @map("checked_in_by")

  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([passId])
  @@index([eventId])
  @@index([checkInStatus])
  @@index([eventId, checkInStatus])
  @@map("event_passes")
}

model SpaceRequest {
  id              String             @id @default(cuid())

  customerName    String             @map("customer_name")
  customerPhone   String             @map("customer_phone")
  customerEmail   String             @map("customer_email")

  preferredSlots  Json               @map("preferred_slots")
  scheduledSlot   DateTime?          @map("scheduled_slot") @db.Timestamptz(3)
  notes           String?
  purpose         String?

  status          SpaceRequestStatus @default(REQUESTED)
  adminNotes      String?            @map("admin_notes")

  booking         Booking?

  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamptz(3)

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("space_requests")
}

model NotificationLog {
  id                String             @id @default(cuid())

  bookingId         String?            @map("booking_id")
  booking           Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  channel           NotificationChannel
  templateName      String             @map("template_name")
  to                String

  status            NotificationStatus @default(PENDING)
  providerMessageId String?            @map("provider_message_id")
  error             String?
  retryCount        Int                @default(0) @map("retry_count")

  sentAt            DateTime?          @map("sent_at") @db.Timestamptz(3)

  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([bookingId])
  @@index([status])
  @@index([channel, status])
  @@map("notification_logs")
}

model StatusHistory {
  id          String   @id @default(cuid())

  bookingId   String   @map("booking_id")
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fromStatus  String   @map("from_status")
  toStatus    String   @map("to_status")
  changedBy   String   @map("changed_by")
  reason      String?

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([bookingId])
  @@index([bookingId, createdAt])
  @@map("status_history")
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([key, createdAt])
  @@map("rate_limit_entries")
}

model AdminSession {
  id             String   @id @default(cuid())
  email          String   @unique
  token          String   @unique
  hashedToken    String?  @unique @map("hashed_token")

  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")

  expiresAt      DateTime @map("expires_at") @db.Timestamptz(3)
  lastActivityAt DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(3)

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([token])
  @@index([hashedToken])
  @@index([expiresAt])
  @@map("admin_sessions")
}
