# ─── Database ────────────────────────────────────────────────────────────────
# Runtime: Supabase Transaction mode pooler (port 6543, required for serverless)
DATABASE_URL=
# Migrations/seed only: Direct connection (port 5432)
DIRECT_DATABASE_URL=

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Found in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for QR code generation and absolute links
APP_BASE_URL=
# For local dev: http://localhost:8888

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed admin emails
ADMIN_ALLOWED_EMAILS=

# bcrypt hash of the admin password (cost factor 12)
# Generate with: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Found in Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Exposed to the browser (Next.js public env var)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# The ONLY booking-confirmation channel. Get a key at https://resend.com/api-keys
# The EMAIL_FROM domain must be verified in Resend before sends will deliver.
RESEND_API_KEY=
EMAIL_FROM=Our Sacred Space <noreply@oursacredspace.in>
# Where new space-rental requests are emailed. Comma-separate for multiple
# recipients. Falls back to the first ADMIN_ALLOWED_EMAILS entry if unset.
SPACE_REQUEST_NOTIFY_EMAIL=

# ─── Sentry (Error Monitoring) ────────────────────────────────────────────────
# Create a project at sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=

# Required for source map uploads during CI builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Dev / Feature Flags ──────────────────────────────────────────────────────
# Set to "true" to enable the devConfirmPayment endpoint (NEVER in production)
# ALLOW_DEV_ENDPOINTS=true

# Set automatically by Netlify; used as the Sentry release identifier
# DEPLOY_ID=
