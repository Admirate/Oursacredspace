# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (use the "Transaction" mode pooler URL)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Found in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Service role key (secret, never expose to client)
SUPABASE_STORAGE_BUCKET=oss-assets

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for QR code generation and absolute links
APP_BASE_URL=https://yoursite.netlify.app
# For local dev: http://localhost:8888

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed admin emails
ADMIN_ALLOWED_EMAILS=admin@yourdomain.com

# bcrypt hash of the admin password (cost factor 12)
# Generate with: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$...

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Found in Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Exposed to the browser (Next.js public env var)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...

# ─── Sentry (Error Monitoring) ────────────────────────────────────────────────
# Create a project at sentry.io → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# Required for source map uploads during CI builds
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=sntrys_...

# ─── WhatsApp (scaffolded, not yet active) ────────────────────────────────────
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Dev / Feature Flags ──────────────────────────────────────────────────────
# Set to "true" to enable the devConfirmPayment endpoint (NEVER in production)
# ALLOW_DEV_ENDPOINTS=true

# Set automatically by Netlify; used as the Sentry release identifier
# DEPLOY_ID=
